# Environment Configuration
# Copy this file to .env and fill in your values

# ── PostgreSQL (used by docker-compose AND the app) ─────
POSTGRES_USER=pai_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=personal_ai_assistant
DATABASE_URL=postgresql+asyncpg://pai_user:change_me_in_production@localhost:5432/personal_ai_assistant
DATABASE_URL_SYNC=postgresql://pai_user:change_me_in_production@localhost:5432/personal_ai_assistant

# ── Qdrant ──────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=personal_ai

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── AWS S3 ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=your-bucket-name

# ── Anthropic / Claude ──────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Embedding ───────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_DIMENSION=384

# ── App ─────────────────────────────────────────────────
APP_NAME=PersonalAIAssistant
DEBUG=true
